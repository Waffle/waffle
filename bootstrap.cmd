powershell -NoProfile -ExecutionPolicy Bypass -Command "$ErrorActionPreference = 'Stop'; $pkgId = 'WixToolset.Sdk'; $pkgIdLower = $pkgId.ToLowerInvariant(); $pkgVersion = '4.0.6'; $pkgFolder = Join-Path '.nuget\packages' ($pkgId + '.' + $pkgVersion); $pkgFile = Join-Path '.nuget\packages' ($pkgId + '.' + $pkgVersion + '.nupkg'); Invoke-WebRequest -UseBasicParsing -Uri ('https://api.nuget.org/v3-flatcontainer/' + $pkgIdLower + '/' + $pkgVersion + '/' + $pkgIdLower + '.' + $pkgVersion + '.nupkg') -OutFile $pkgFile; Expand-Archive -Path $pkgFile -DestinationPath $pkgFolder -Force; $wixPropsFile = Join-Path $pkgFolder 'tools\wix.props'; $wixPropsContent = Get-Content -Raw $wixPropsFile; $wixPropsContent = $wixPropsContent.Replace('$([MSBuild]::NormalizePath($(MSBuildProjectDirectory), $(ProjectAssetsFile)))', '$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine($(MSBuildProjectDirectory), $(ProjectAssetsFile)))))').Replace('$([MSBuild]::NormalizeDirectory($(MSBuildProjectDirectory), $(PdbOutputDir)))', '$([System.String]::Concat($([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine($(MSBuildProjectDirectory), $(PdbOutputDir))))), ''\''))'); [System.IO.File]::WriteAllText($wixPropsFile, $wixPropsContent); $wixTargetsFile = Join-Path $pkgFolder 'tools\wix.targets'; $wixTargetsContent = Get-Content -Raw $wixTargetsFile; $wixTargetsContent = $wixTargetsContent.Replace('$([MSBuild]::NormalizePath($(MSBuildProjectDirectory), $(ProjectAssetsFile)))', '$([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine($(MSBuildProjectDirectory), $(ProjectAssetsFile)))))').Replace('$([MSBuild]::NormalizeDirectory($(MSBuildProjectDirectory), $(PdbOutputDir)))', '$([System.String]::Concat($([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine($(MSBuildProjectDirectory), $(PdbOutputDir))))), ''\''))').Replace('$([MSBuild]::NormalizeDirectory($(CabinetCachePath), %%(CultureGroup.OutputFolder)))', '$([System.String]::Concat($([System.IO.Path]::GetFullPath($([System.IO.Path]::Combine($(CabinetCachePath), %%(CultureGroup.OutputFolder))))), ''\''))').Replace('$([MSBuild]::NormalizeDirectory($(IntermediateOutputPath)))', '$([System.String]::Concat($([System.IO.Path]::GetFullPath($(IntermediateOutputPath))), ''\''))'); [System.IO.File]::WriteAllText($wixTargetsFile, $wixTargetsContent); $wixBuildTaskDir = Join-Path $pkgFolder 'tools\net472'; Copy-Item '.nuget\packages\Microsoft.Build.14.3.0\lib\net45\Microsoft.Build.dll' $wixBuildTaskDir -Force; Copy-Item '.nuget\packages\Microsoft.Build.Framework.14.3.0\lib\net45\Microsoft.Build.Framework.dll' $wixBuildTaskDir -Force; Copy-Item '.nuget\packages\Microsoft.Build.Tasks.Core.14.3.0\lib\net45\Microsoft.Build.Tasks.Core.dll' $wixBuildTaskDir -Force; Copy-Item '.nuget\packages\Microsoft.Build.Utilities.Core.14.3.0\lib\net45\Microsoft.Build.Utilities.Core.dll' $wixBuildTaskDir -Force; Remove-Item -Path $pkgFile -Force"
